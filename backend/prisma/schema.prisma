// ---- T13: Tipos de Contratación Parametrizados y Catálogos Funcionales ----
model TipoContratacion {
  id                        String                               @id @default(cuid())
  codigo                    String                               @unique
  nombre                    String
  descripcion               String?
  requiereMedidor           Boolean                              @default(true)  @map("requiere_medidor")
  claseProceso              String?                              @map("clase_proceso") // AN | CN | PB | BJ
  esContratoFormal          Boolean                              @default(true) @map("es_contrato_formal")
  requiereSolicitudPrevia   Boolean                              @default(false) @map("requiere_solicitud_previa")
  diasCaducidadSolicitud    Int?                                 @map("dias_caducidad_solicitud")
  organismoAprobacion       String?                              @map("organismo_aprobacion")
  diasPlazoAprobacion       Int?                                 @map("dias_plazo_aprobacion")
  periodicidadesPermitidas  String?                              @map("periodicidades_permitidas") // ANUAL,MENSUAL,SEMESTRAL,TRIMESTRAL
  tiposClientePermitidos    String?                              @map("tipos_cliente_permitidos")  // EMP,GRUPO,MUNICIPAL,OFICIAL,PARTICULAR
  administracionId          String?                              @map("administracion_id")
  claseContratoId           String?                              @map("clase_contrato_id")
  activo                    Boolean                              @default(true)
  createdAt                 DateTime                             @default(now()) @map("created_at")
  updatedAt                 DateTime                             @updatedAt @map("updated_at")
  administracion            Administracion?                      @relation(fields: [administracionId], references: [id], onDelete: SetNull)
  claseContrato             ClaseContrato?                       @relation(fields: [claseContratoId], references: [id], onDelete: SetNull)
  contratos                 Contrato[]
  conceptos                 ConceptoCobroTipoContratacion[]
  clausulas                 ClausulaTipoContratacion[]
  documentos                DocumentoRequeridoTipoContratacion[]
  variables                 VariableTipoContratacion[]

  @@index([administracionId])
  @@index([claseContratoId])
  @@map("tipos_contratacion")
}

