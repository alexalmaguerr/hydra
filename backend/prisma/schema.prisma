generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Territorial ----
model Administracion {
  id                String             @id @default(cuid())
  nombre            String
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  zonas             Zona[]
  tiposContratacion TipoContratacion[]
  sectores          SectorHidraulico[]
  oficinas          Oficina[]

  @@map("administraciones")
}

model Zona {
  id               String          @id @default(cuid())
  administracionId String          @map("administracion_id")
  nombre           String
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  administracion   Administracion  @relation(fields: [administracionId], references: [id], onDelete: Restrict)
  distritos        Distrito[]
  contratos        Contrato[]
  rutas            Ruta[]
  medidoresBodega  MedidorBodega[] @relation("MedidorBodegaZona")
  lotesLecturas    LoteLecturas[]

  @@index([administracionId])
  @@map("zonas")
}

model Distrito {
  id        String   @id @default(cuid())
  zonaId    String   @map("zona_id")
  nombre    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  zona      Zona     @relation(fields: [zonaId], references: [id], onDelete: Restrict)
  rutas     Ruta[]

  @@index([zonaId])
  @@map("distritos")
}

// ---- Ciclo de obra ----
model Factibilidad {
  id             String         @id @default(cuid())
  predio         String
  solicitante    String
  direccion      String
  estado         String
  fecha          String
  notas          String         @default("")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  construcciones Construccion[]

  @@map("factibilidades")
}

model Construccion {
  id             String       @id @default(cuid())
  factibilidadId String       @map("factibilidad_id")
  nombre         String
  ubicacion      String
  estado         String
  fecha          String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  factibilidad   Factibilidad @relation(fields: [factibilidadId], references: [id], onDelete: Restrict)
  tomas          Toma[]

  @@index([factibilidadId])
  @@map("construcciones")
}

model Toma {
  id             String       @id @default(cuid())
  construccionId String       @map("construccion_id")
  ubicacion      String
  tipo           String // Agua | Saneamiento | Alcantarillado
  estado         String // Disponible | Asignada
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  construccion   Construccion @relation(fields: [construccionId], references: [id], onDelete: Restrict)
  contratos      Contrato[]

  @@index([construccionId])
  @@map("tomas")
}

// ---- Contratos y medidores ----
model Contrato {
  id                      String                @id @default(cuid())
  numeroContrato          Int                   @default(autoincrement()) @unique @map("numero_contrato")
  tomaId                  String?               @map("toma_id")
  puntoServicioId         String?               @map("punto_servicio_id")
  domicilioId             String?               @map("domicilio_id")
  tipoContratacionId      String?               @map("tipo_contratacion_id")
  tipoContrato            String                @map("tipo_contrato")
  tipoServicio            String                @map("tipo_servicio")
  nombre                  String
  rfc                     String
  razonSocial             String?               @map("razon_social")
  regimenFiscal           String?               @map("regimen_fiscal")
  constanciaFiscalUrl     String?               @map("constancia_fiscal_url")
  direccion               String
  contacto                String
  estado                  String
  fecha                   String
  fechaBaja               String?               @map("fecha_baja")
  bloqueadoJuridico       Boolean               @default(false) @map("bloqueado_juridico")
  medidorId               String?               @map("medidor_id")
  rutaId                  String?               @map("ruta_id")
  zonaId                  String?               @map("zona_id")
  domiciliado             Boolean               @default(false)
  fechaReconexionPrevista String?               @map("fecha_reconexion_prevista")
  ceaNumContrato          String?               @map("cea_num_contrato")
  // Campos del contrato según PRD y CIG2018 (P1)
  actividadId             String?               @map("actividad_id")
  categoriaId             String?               @map("categoria_id")
  referenciaContratoAnterior String?            @map("referencia_contrato_anterior")
  observaciones           String?               @db.Text
  tipoEnvioFactura        String?               @map("tipo_envio_factura") // PAPEL | PDF | PAPEL_PDF
  indicadorEmisionRecibo  Boolean               @default(true)  @map("indicador_emision_recibo")
  indicadorExentarFacturacion Boolean           @default(false) @map("indicador_exentar_facturacion")
  indicadorContactoCorreo Boolean               @default(false) @map("indicador_contacto_correo")
  cicloFacturacion        String?               @map("ciclo_facturacion") // ANUAL | MENSUAL | SEMESTRAL | TRIMESTRAL
  superficiePredio        Decimal?              @map("superficie_predio")  @db.Decimal(10, 2)
  superficieConstruida    Decimal?              @map("superficie_construida") @db.Decimal(10, 2)
  mesesAdeudo             Int?                  @map("meses_adeudo")
  unidadesServidas        Int?                  @map("unidades_servidas")
  personasHabitanVivienda Int?                  @map("personas_habitan_vivienda")
  textoContratoSnapshot   String?               @map("texto_contrato_snapshot") @db.Text
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  toma                    Toma?                 @relation(fields: [tomaId], references: [id], onDelete: SetNull)
  puntoServicio           PuntoServicio?        @relation(fields: [puntoServicioId], references: [id], onDelete: SetNull)
  domicilio               Domicilio?            @relation(fields: [domicilioId], references: [id], onDelete: SetNull)
  tipoContratacion        TipoContratacion?     @relation(fields: [tipoContratacionId], references: [id], onDelete: SetNull)
  zona                    Zona?                 @relation(fields: [zonaId], references: [id], onDelete: SetNull)
  ruta                    Ruta?                 @relation(fields: [rutaId], references: [id], onDelete: SetNull)
  actividad               CatalogoActividad?    @relation(fields: [actividadId], references: [id], onDelete: SetNull)
  categoria               CatalogoCategoria?    @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  medidor                 Medidor?
  costosContrato          CostoContrato[]
  consumos                Consumo[]
  timbrados               Timbrado[]
  recibos                 Recibo[]
  pagos                   Pago[]
  ordenes                 Orden[]
  personas                RolPersonaContrato[]
  historico               HistoricoContrato[]
  tramites                Tramite[]
  convenios               Convenio[]
  anticipos               Anticipo[]
  sigeHydraCasos          SigeHydra[]
  variablesCapturadas     Json?                 @map("variables_capturadas")
  procesosContratacion    ProcesoContratacion[]
  conceptosContrato       ContratoConcepto[]

  @@index([tomaId])
  @@index([puntoServicioId])
  @@index([domicilioId])
  @@index([tipoContratacionId])
  @@index([rutaId])
  @@index([zonaId])
  @@index([medidorId])
  @@index([actividadId])
  @@index([categoriaId])
  @@map("contratos")
}

model CostoContrato {
  id         String   @id @default(cuid())
  contratoId String   @map("contrato_id")
  concepto   String
  monto      Decimal  @db.Decimal(10, 2)
  periodo    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@map("costos_contrato")
}

model ContratoConcepto {
  id                 String        @id @default(cuid())
  contratoId         String        @map("contrato_id")
  conceptoCobroId    String        @map("concepto_cobro_id")
  nombre             String
  tipo               String
  cantidad           Decimal       @default(1) @db.Decimal(10, 4)
  precioBase         Decimal       @default(0) @map("precio_base") @db.Decimal(10, 2)
  precioProporcional Decimal       @default(0) @map("precio_proporcional") @db.Decimal(10, 4)
  importe            Decimal       @db.Decimal(10, 2)
  ivaPct             Decimal       @default(16) @map("iva_pct") @db.Decimal(5, 2)
  ivaImporte         Decimal       @default(0) @map("iva_importe") @db.Decimal(10, 2)
  obligatorio        Boolean       @default(true)
  orden              Int           @default(0)
  createdAt          DateTime      @default(now()) @map("created_at")
  contrato           Contrato      @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  conceptoCobro      ConceptoCobro @relation(fields: [conceptoCobroId], references: [id])

  @@index([contratoId])
  @@map("contrato_conceptos")
}

model Medidor {
  id               String                  @id @default(cuid())
  contratoId       String                  @unique @map("contrato_id")
  serie            String
  estado           String
  cobroDiferido    Boolean                 @default(false) @map("cobro_diferido")
  lecturaInicial   Int                     @map("lectura_inicial")
  marcaId          String?                 @map("marca_id")
  modeloId         String?                 @map("modelo_id")
  calibreId        String?                 @map("calibre_id")
  emplazamientoId  String?                 @map("emplazamiento_id")
  tipoContadorId   String?                 @map("tipo_contador_id")
  digitos          Int?
  tipoEsfera       String?                 @map("tipo_esfera")
  tipoTelemetria   String?                 @map("tipo_telemetria")
  fechaInstalacion DateTime?               @map("fecha_instalacion")
  fechaUltimaVerif DateTime?               @map("fecha_ultima_verificacion")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  contrato         Contrato                @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  marca            CatalogoMarcaMedidor?   @relation(fields: [marcaId], references: [id], onDelete: SetNull)
  modelo           CatalogoModeloMedidor?  @relation(fields: [modeloId], references: [id], onDelete: SetNull)
  calibre          CatalogoCalibre?        @relation(fields: [calibreId], references: [id], onDelete: SetNull)
  emplazamiento    CatalogoEmplazamiento?  @relation(fields: [emplazamientoId], references: [id], onDelete: SetNull)
  tipoContador     CatalogoTipoContador?   @relation(fields: [tipoContadorId], references: [id], onDelete: SetNull)

  @@index([contratoId])
  @@index([marcaId])
  @@index([modeloId])
  @@index([calibreId])
  @@map("medidores")
}

model MedidorBodega {
  id              String                  @id @default(cuid())
  serie           String
  zonaId          String?                 @map("zona_id")
  estado          String // Disponible | En reparación | Retirado
  marcaId         String?                 @map("marca_id")
  modeloId        String?                 @map("modelo_id")
  calibreId       String?                 @map("calibre_id")
  digitos         Int?
  fechaIngreso    DateTime?               @map("fecha_ingreso")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  zona            Zona?                   @relation("MedidorBodegaZona", fields: [zonaId], references: [id], onDelete: SetNull)
  marca           CatalogoMarcaMedidor?   @relation(fields: [marcaId], references: [id], onDelete: SetNull)
  modelo          CatalogoModeloMedidor?  @relation(fields: [modeloId], references: [id], onDelete: SetNull)
  calibre         CatalogoCalibre?        @relation(fields: [calibreId], references: [id], onDelete: SetNull)

  @@index([zonaId])
  @@index([marcaId])
  @@map("medidores_bodega")
}

model Ruta {
  id            String         @id @default(cuid())
  zonaId        String         @map("zona_id")
  distritoId    String?        @map("distrito_id")
  sector        String
  libreta       String
  lecturista    String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  zona          Zona           @relation(fields: [zonaId], references: [id], onDelete: Restrict)
  distrito      Distrito?      @relation(fields: [distritoId], references: [id], onDelete: SetNull)
  contratos     Contrato[]
  lotesLecturas LoteLecturas[]

  @@index([zonaId])
  @@index([distritoId])
  @@map("rutas")
}

// ---- Quejas y Aclaraciones ----
model QuejaAclaracion {
  id            String   @id @default(cuid())
  contratoId    String   @map("contrato_id")
  fecha         DateTime @default(now())
  tipo          String // 'Queja' | 'Aclaración'
  descripcion   String
  estado        String   @default("Registrada")
  atendidoPor   String?  @map("atendido_por")
  categoria     String?
  prioridad     String   @default("Media")
  canal         String   @default("Ventanilla")
  areaAsignada  String   @default("Atención a clientes") @map("area_asignada")
  enlaceExterno String?  @map("enlace_externo")
  motivoCierre  String?  @map("motivo_cierre")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  seguimientos SeguimientoQueja[]

  @@index([contratoId])
  @@map("quejas_aclaraciones")
}

model SeguimientoQueja {
  id        String   @id @default(cuid())
  quejaId   String   @map("queja_id")
  fecha     DateTime @default(now())
  nota      String
  usuario   String
  tipo      String // 'nota' | 'cambio_estado' | 'reasignacion' | 'contacto_cliente'
  createdAt DateTime @default(now()) @map("created_at")

  queja QuejaAclaracion @relation(fields: [quejaId], references: [id], onDelete: Cascade)

  @@index([quejaId])
  @@map("seguimientos_queja")
}

// ---- Portal de clientes ----
model Consumo {
  id         String    @id @default(cuid())
  contratoId String    @map("contrato_id")
  periodo    String
  m3         Decimal   @db.Decimal(10, 2)
  tipo       String // Real | Promedio histórico | Mixto | Consumo fijo
  confirmado Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  contrato   Contrato  @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  timbrado   Timbrado?

  @@index([contratoId])
  @@map("consumos")
}

model Timbrado {
  id               String   @id @default(cuid())
  contratoId       String   @map("contrato_id")
  consumoId        String?  @unique @map("consumo_id")
  uuid             String   @default("")
  estado           String // Timbrada OK | Error PAC | Pendiente
  periodo          String
  subtotal         Decimal  @db.Decimal(10, 2)
  iva              Decimal  @db.Decimal(10, 2)
  total            Decimal  @db.Decimal(10, 2)
  fechaEmision     String   @map("fecha_emision")
  fechaVencimiento String   @map("fecha_vencimiento")
  error            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  contrato         Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  consumo          Consumo? @relation(fields: [consumoId], references: [id], onDelete: SetNull)
  recibos          Recibo[]
  pagos            Pago[]

  @@index([contratoId])
  @@map("timbrados")
}

model Recibo {
  id               String   @id @default(cuid())
  contratoId       String   @map("contrato_id")
  timbradoId       String   @map("timbrado_id")
  saldoVigente     Decimal  @map("saldo_vigente") @db.Decimal(10, 2)
  saldoVencido     Decimal  @map("saldo_vencido") @db.Decimal(10, 2)
  fechaVencimiento String   @map("fecha_vencimiento")
  parcialidades    Int      @default(1)
  impreso          Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  contrato         Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  timbrado         Timbrado @relation(fields: [timbradoId], references: [id], onDelete: Cascade)
  pagos            Pago[]

  @@index([contratoId])
  @@index([timbradoId])
  @@map("recibos")
}

model Pago {
  id          String     @id @default(cuid())
  contratoId  String     @map("contrato_id")
  reciboId    String?    @map("recibo_id")
  timbradoId  String?    @map("timbrado_id")
  convenioId  String?    @map("convenio_id")
  formaPagoId String?    @map("forma_pago_id")
  monto       Decimal    @db.Decimal(10, 2)
  fecha       String
  tipo        String // legacy: Efectivo | Transferencia | Tarjeta | SPEI | OXXO | CoDi | WEB
  concepto    String
  origen      String     @default("nativo") // nativo | externo
  oficina     String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  contrato    Contrato   @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  recibo      Recibo?    @relation(fields: [reciboId], references: [id], onDelete: SetNull)
  timbrado    Timbrado?  @relation(fields: [timbradoId], references: [id], onDelete: SetNull)
  convenio    Convenio?  @relation(fields: [convenioId], references: [id], onDelete: SetNull)
  formaPago   FormaPago? @relation(fields: [formaPagoId], references: [id], onDelete: SetNull)

  @@index([contratoId])
  @@index([reciboId])
  @@index([convenioId])
  @@index([formaPagoId])
  @@map("pagos")
}

// ---- Auth ----
enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERADOR
  LECTURISTA
  ATENCION_CLIENTES
  CLIENTE
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String   @map("password_hash")
  name              String
  role              UserRole @default(OPERADOR)
  administracionIds String[] @map("administracion_ids")
  zonaIds           String[] @map("zona_ids")
  contratoIds       String[] @map("contrato_ids")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ---- T01: Catálogos de lecturas ----
model Contratista {
  id          String       @id @default(cuid())
  nombre      String
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  lecturistas Lecturista[]

  @@map("contratistas")
}

model Lecturista {
  id            String       @id @default(cuid())
  codigo        String       @unique
  nombre        String
  contratistaId String?      @map("contratista_id")
  activo        Boolean      @default(true)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  contratista   Contratista? @relation(fields: [contratistaId], references: [id], onDelete: SetNull)
  lecturas      Lectura[]

  @@map("lecturistas")
}

model CatalogoIncidencia {
  id          String    @id @default(cuid())
  codigo      String    @unique
  descripcion String
  esAveria    Boolean   @default(false) @map("es_averia")
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lecturas    Lectura[]

  @@map("catalogo_incidencias")
}

model LoteLecturas {
  id             String    @id @default(cuid())
  zonaId         String?   @map("zona_id")
  rutaId         String?   @map("ruta_id")
  periodo        String
  tipoLote       String    @map("tipo_lote")
  archivoNombre  String    @map("archivo_nombre")
  archivoHash    String?   @map("archivo_hash")
  estado         String    @default("Pendiente")
  totalRegistros Int       @default(0) @map("total_registros")
  totalValidos   Int       @default(0) @map("total_validos")
  totalConError  Int       @default(0) @map("total_con_error")
  errores        Json?
  cargadoPor     String?   @map("cargado_por")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  zona           Zona?     @relation(fields: [zonaId], references: [id], onDelete: SetNull)
  ruta           Ruta?     @relation(fields: [rutaId], references: [id], onDelete: SetNull)
  lecturas       Lectura[]

  @@index([zonaId])
  @@index([rutaId])
  @@index([periodo])
  @@map("lotes_lecturas")
}

model Lectura {
  id                 String              @id @default(cuid())
  loteId             String              @map("lote_id")
  contratoId         String              @map("contrato_id")
  lecturistaId       String?             @map("lecturista_id")
  incidenciaId       String?             @map("incidencia_id")
  periodo            String
  lecturaActual      Int?                @map("lectura_actual")
  lecturaAnterior    Int?                @map("lectura_anterior")
  consumoReal        Int?                @map("consumo_real")
  consumoEstimado    Int?                @map("consumo_estimado")
  esEstimada         Boolean             @default(false) @map("es_estimada")
  lecturaMinZona     Int?                @map("lectura_min_zona")
  lecturaMaxZona     Int?                @map("lectura_max_zona")
  urlFoto            String?             @map("url_foto")
  estado             String              @default("Pendiente")
  motivoInvalidacion String?             @map("motivo_invalidacion")
  datosRaw           Json?               @map("datos_raw")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  lote               LoteLecturas        @relation(fields: [loteId], references: [id], onDelete: Cascade)
  lecturista         Lecturista?         @relation(fields: [lecturistaId], references: [id], onDelete: SetNull)
  incidencia         CatalogoIncidencia? @relation(fields: [incidenciaId], references: [id], onDelete: SetNull)

  @@index([loteId])
  @@index([contratoId])
  @@index([periodo])
  @@index([estado])
  @@map("lecturas")
}

model MensajeLecturista {
  id         String   @id @default(cuid())
  loteId     String?  @map("lote_id")
  contratoId String?  @map("contrato_id")
  mensaje    String
  tipo       String   @default("comentario")
  visible    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([loteId])
  @@index([contratoId])
  @@map("mensajes_lecturistas")
}

// ---- T02: Pagos externos ----
model PagoExterno {
  id            String   @id @default(cuid())
  recaudador    String
  archivoNombre String   @map("archivo_nombre")
  referencia    String?
  contratoRaw   String?  @map("contrato_raw")
  contratoId    String?  @map("contrato_id")
  monto         Decimal  @db.Decimal(10, 2)
  fechaPagoReal DateTime @map("fecha_pago_real")
  formaPago     String?  @map("forma_pago")
  canal         String?
  oficina       String?
  estado        String   @default("pendiente_conciliar")
  motivoRechazo String?  @map("motivo_rechazo")
  reciboId      String?  @map("recibo_id")
  datosRaw      Json?    @map("datos_raw")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([contratoId])
  @@index([estado])
  @@index([recaudador])
  @@index([fechaPagoReal])
