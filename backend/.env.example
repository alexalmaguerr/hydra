# PostgreSQL connection for ctcf API
# Local example: postgresql://postgres:postgres@localhost:5432/ctcf_dev
# Docker Compose: postgresql://postgres:postgres@postgres:5432/ctcf_dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ctcf_dev"

# Optional: port for the API (default 3001)
PORT=3001

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:8080

# JWT secret for access tokens (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Token fijo para endpoint SIGE Hydra (servicio externo)
SIGE_HYDRA_API_TOKEN=your-fixed-secret-token

# Feature flags (true = habilitado)
FEATURE_FACTURACION_CONTRATACION=false
